<?xml version="1.0" encoding="utf-8"?>
<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>ZWB_Bubbler</defName>
		<label>bubbler</label>
		<description>A tiny omnivorous crab.</description>
		<statBases>
			<MoveSpeed>3.2</MoveSpeed>
			<ComfyTemperatureMin>-15</ComfyTemperatureMin>
			<MarketValue>110</MarketValue>
			<Wildness>0.4</Wildness>
			<LeatherAmount>0</LeatherAmount>
			<ArmorRating_Blunt>0.15</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.2</ArmorRating_Sharp>
		</statBases>
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>ZWB_EggBubblerUnfertilized</eggUnfertilizedDef>
				<eggFertilizedDef>ZWB_EggBubblerFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>3.9</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>1~2</eggCountRange>
			</li>
		</comps>
		<race>
			<body>ZWB_CrabLike</body>
			<herdAnimal>true</herdAnimal>
			<baseBodySize>0.2</baseBodySize>
			<baseHungerRate>0.12</baseHungerRate>
			<baseHealthScale>0.45</baseHealthScale>		<!-- slightly higher than the average animal this size -->
			<foodType>OmnivoreRoughAnimal</foodType>
			<trainability>Intermediate</trainability>
			<lifeExpectancy>15</lifeExpectancy>
			<!-- <useMeatFrom>ZWB_Bubbler</useMeatFrom> -->
			<meatLabel>crab meat</meatLabel>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.15</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.22</minAge>
					<soundWounded>ZWB_SmallCrab_Wounded</soundWounded>
					<soundDeath>ZWB_SmallCrab_Death</soundDeath>
					<soundCall>ZWB_SmallCrab_Call</soundCall>
					<soundAngry>ZWB_SmallCrab_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
			<soundEating>Rodent_Eat</soundEating>
			<packAnimal>false</packAnimal>
		</race>
		<tradeTags>
			<li>AnimalExotic</li>
		</tradeTags>
		<tools>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
			<li>
				<label>left claw</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>7</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>ZWB_LeftClaw</linkedBodyPartsGroup>
				<chanceFactor>0.6</chanceFactor>
			</li>
			<li>
				<label>right claw</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>7</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>ZWB_RightClaw</linkedBodyPartsGroup>
				<chanceFactor>0.6</chanceFactor>
			</li>
		</tools>
	</ThingDef>


	<PawnKindDef ParentName="AnimalKindBase">
		<defName>ZWB_Bubbler</defName>
		<label>bubbler</label>
		<race>ZWB_Bubbler</race>
		<combatPower>80</combatPower>
		<ecoSystemWeight>0.20</ecoSystemWeight>
		<wildGroupSize>3~5</wildGroupSize>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>ZWB_Textures/Animals/Bubbler/Bubbler</texPath>
					<drawSize>0.4</drawSize>
				</bodyGraphicData>
				<dessicatedBodyGraphicData>
					<texPath>ZWB_Textures/Animals/Bubbler/Dessicated_Bubbler</texPath>
					<drawSize>0.4</drawSize>
				</dessicatedBodyGraphicData>
			</li>
			<li>
				<bodyGraphicData>
					<texPath>ZWB_Textures/Animals/Bubbler/Bubbler</texPath>
					<drawSize>0.6</drawSize>
				</bodyGraphicData>
				<dessicatedBodyGraphicData>
					<texPath>ZWB_Textures/Animals/Bubbler/Dessicated_Bubbler</texPath>
					<drawSize>0.6</drawSize>
				</dessicatedBodyGraphicData>
			</li>
			<li>
				<bodyGraphicData>
					<texPath>ZWB_Textures/Animals/Bubbler/Bubbler</texPath>
					<drawSize>0.85</drawSize>
				</bodyGraphicData>
				<dessicatedBodyGraphicData>
					<texPath>ZWB_Textures/Animals/Bubbler/Dessicated_Bubbler</texPath>
					<drawSize>0.85</drawSize>
				</dessicatedBodyGraphicData>
			</li>
		</lifeStages>
	</PawnKindDef>



	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggBubblerFertilized</defName>
		<label>bubbler egg (fert.)</label>
		<description>A fertilized bubbler egg. If all goes well, it should hatch into a baby bubbler. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(52,153,133)</color>
			<drawSize>0.6</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>16.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>3.5</hatcherDaystoHatch>
				<hatcherPawn>ZWB_Bubbler</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



	<ThingDef ParentName="EggUnfertBase">
		<defName>ZWB_EggBubblerUnfertilized</defName>
		<label>bubbler egg (unfert.)</label>
		<description>An unfertilized bubbler egg. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(73,133,120)</color>
			<drawSize>0.6</drawSize>
		</graphicData>
		<statBases>
			<MarketValue>8.0</MarketValue>
			<Nutrition>0.5</Nutrition>
		</statBases>
	</ThingDef>


</Defs>
