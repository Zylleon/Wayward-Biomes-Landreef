	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggLemonGrabblerFertilized</defName>
		<label>lemon grabbler egg (fert.)</label>
		<description>A fertilized lemon grabbler egg. If all goes well, it should hatch into a baby lemon grabbler. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(166,124,109)</color>
			<drawSize>0.8</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>16.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>5.2</hatcherDaystoHatch>
				<hatcherPawn>ZWB_LemonGrabbler</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



