<?xml version="1.0" encoding="utf-8"?>
<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>ZWB_LemonGrabbler</defName>
		<label>lemon grabbler</label>
		<description>A mid-sized crab. Quite sturdy, and capable of being trained as a work animal.</description>
		<statBases>
			<MoveSpeed>4.5</MoveSpeed>
			<ComfyTemperatureMin>-25</ComfyTemperatureMin>
			<MarketValue>350</MarketValue>
			<Wildness>0</Wildness>
			<LeatherAmount>0</LeatherAmount>
			<ArmorRating_Blunt>0.25</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.4</ArmorRating_Sharp>
		</statBases>
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>ZWB_EggLemonGrabblerUnfertilized</eggUnfertilizedDef>
				<eggFertilizedDef>ZWB_EggLemonGrabblerFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>4.5</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>1~2</eggCountRange>
			</li>
		</comps>
		<race>
			<body>ZWB_CrabLike</body>
			<herdAnimal>false</herdAnimal>
			<baseBodySize>0.9</baseBodySize>
			<baseHungerRate>0.4</baseHungerRate>
			<baseHealthScale>1.1</baseHealthScale>		
			<foodType>OmnivoreRoughAnimal</foodType>
			<trainability>Advanced</trainability>
			<lifeExpectancy>18</lifeExpectancy>
			<!-- <useMeatFrom>ZWB_LemonGrabbler</useMeatFrom> -->
			<meatLabel>crab meat</meatLabel>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.25</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.45</minAge>
					<soundWounded>ZWB_SmallCrab_Wounded</soundWounded>
					<soundDeath>ZWB_SmallCrab_Death</soundDeath>
					<soundCall>ZWB_SmallCrab_Call</soundCall>
					<soundAngry>ZWB_SmallCrab_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
			<soundEating>Rodent_Eat</soundEating>
			<packAnimal>false</packAnimal>
		</race>
		<tradeTags>
			<li>AnimalCommon</li>
			<li>AnimalPet</li>
		</tradeTags>
		<tools>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>8</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
			<li>
				<label>left claw</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>11</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>ZWB_LeftClaw</linkedBodyPartsGroup>
				<chanceFactor>0.6</chanceFactor>
			</li>
			<li>
				<label>right claw</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>11</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>ZWB_RightClaw</linkedBodyPartsGroup>
				<chanceFactor>0.6</chanceFactor>
			</li>
		</tools>
	</ThingDef>


