	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggSnurbleFertilized</defName>
		<label>snurble egg (fert.)</label>
		<description>A fertilized snurble egg. If all goes well, it should hatch into a baby snurble. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(174,133,196)</color>
			<drawSize>0.7</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>16.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>5</hatcherDaystoHatch>
				<hatcherPawn>ZWB_Snurble</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



