	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggCoiledBitteFertilized</defName>
		<label>coiled bitte egg (fert.)</label>
		<description>A fertilized coiled bitte egg. If all goes well, it should hatch into a baby coiled bitte. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(163,85,98)</color>
			<drawSize>0.6</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>16.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>3.5</hatcherDaystoHatch>
				<hatcherPawn>ZWB_CoiledBitte</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



