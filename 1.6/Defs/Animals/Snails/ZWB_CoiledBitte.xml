<?xml version="1.0" encoding="utf-8"?>
<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>ZWB_CoiledBitte</defName>
		<label>coiled bitte</label>
		<description>A tiny, hardy snail, commonly found on tidewrack reefs. It secretes a fine silk that can be harvested periodically.</description>
		<statBases>
			<MoveSpeed>2.2</MoveSpeed>
			<ComfyTemperatureMin>-25</ComfyTemperatureMin>
			<MarketValue>30</MarketValue>
			<Wildness>0.2</Wildness>
			<LeatherAmount>0</LeatherAmount>
			<ArmorRating_Blunt>0.2</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.4</ArmorRating_Sharp>
		</statBases>
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>ZWB_EggCoiledBitteUnfertilized</eggUnfertilizedDef>
				<eggFertilizedDef>ZWB_EggCoiledBitteFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>3.9</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>1~2</eggCountRange>
			</li>
				<li Class="Tidewrack.CompProperties_Gatherable">
				<itemDef>ZWB_SnailSilk</itemDef>
				<growthLabel>Silk production</growthLabel>
				<gatherIntervalDays>10</gatherIntervalDays>
				<itemAmount>8</itemAmount>
				<workAmount>600</workAmount>
			</li>
		</comps>
		<race>
			<body>ZWB_Snail</body>
			<herdAnimal>false</herdAnimal>
			<baseBodySize>0.18</baseBodySize>
			<baseHungerRate>0.1</baseHungerRate>
			<baseHealthScale>0.4</baseHealthScale>		<!-- slightly higher than the average animal this size -->
			<foodType>OmnivoreRoughAnimal</foodType>
			<trainability>None</trainability>
			<roamMtbDays>3</roamMtbDays>
			<lifeExpectancy>9</lifeExpectancy>
			<useMeatFrom>ZWB_Snurble</useMeatFrom>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.09</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.18</minAge>
					<soundWounded>Pawn_Boomrat_Wounded</soundWounded>
					<soundDeath>Pawn_Boomrat_Death</soundDeath>
					<soundCall>Pawn_Boomrat_Call</soundCall>
					<soundAngry>Pawn_Boomrat_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
			<soundEating>Rodent_Eat</soundEating>
			<packAnimal>false</packAnimal>
		</race>
		<tradeTags>
			<li>AnimalUncommon</li>
			<li>AnimalFighter</li>
		</tradeTags>
		<tools>
			<li>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>5.5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.7</chanceFactor>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>6</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
		</tools>
	</ThingDef>


