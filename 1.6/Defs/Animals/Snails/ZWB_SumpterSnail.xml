	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggSumpterSnailFertilized</defName>
		<label>sumpter snail egg (fert.)</label>
		<description>A fertilized sumpter snail egg. If all goes well, it should hatch into a baby sumpter snail. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(110,147,207)</color>
			<drawSize>1.5</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>46.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>12</hatcherDaystoHatch>
				<hatcherPawn>ZWB_SumpterSnail</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



