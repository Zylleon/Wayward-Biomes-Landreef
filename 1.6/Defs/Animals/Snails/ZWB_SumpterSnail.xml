<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>ZWB_SumpterSnail</defName>
		<label>sumpter snail</label>
		<description>An emormous sea snail, adapted for land. Though not the fastest, these snails can carry quite a heavy pack.</description>
		<statBases>
			<MoveSpeed>3.3</MoveSpeed>
			<ComfyTemperatureMin>-20</ComfyTemperatureMin>
			<MarketValue>470</MarketValue>
			<Wildness>0.6</Wildness>
			<LeatherAmount>0</LeatherAmount>
			<ArmorRating_Blunt>0.15</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.30</ArmorRating_Sharp>
		</statBases>
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>ZWB_EggSumpterSnailUnfertilized</eggUnfertilizedDef>
				<eggFertilizedDef>ZWB_EggSumpterSnailFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>11.5</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>1~1</eggCountRange>
			</li>
		</comps>
		<race>
			<body>ZWB_Snail</body>
			<herdAnimal>true</herdAnimal>
			<baseBodySize>3.6</baseBodySize>
			<baseHungerRate>1.3</baseHungerRate>
			<baseHealthScale>3.5</baseHealthScale>
			<foodType>VegetarianRoughAnimal</foodType>
			<trainability>None</trainability>
			<meatLabel>snail meat</meatLabel>
			<leatherDef>Leather_Plain</leatherDef>
			<lifeExpectancy>33</lifeExpectancy>
			<manhunterOnDamageChance>0.50</manhunterOnDamageChance>
			<manhunterOnTameFailChance>0</manhunterOnTameFailChance>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.3</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.63</minAge>
					<soundWounded>ZWB_LargeSnail_Wounded</soundWounded>
					<soundDeath>ZWB_LargeSnail_Death</soundDeath>
					<soundCall>ZWB_LargeSnail_Call</soundCall>
					<soundAngry>ZWB_LargeSnail_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
			<soundEating>Rodent_Eat</soundEating>
			<packAnimal>true</packAnimal>
		</race>
		<tradeTags>
			<li>AnimalExotic</li>
		</tradeTags>
		<tools>
			<li>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>15</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.2</chanceFactor>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>18</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.7</chanceFactor>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>19</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
		</tools>
	</ThingDef>


