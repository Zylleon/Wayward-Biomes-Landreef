<?xml version="1.0" encoding="utf-8"?>
<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>ZWB_MediMollusc</defName>
		<label>medi-mollusc</label>
		<description>A medium sized genetically altered snail. The medi-mollusc was created to be a living pharmacy, but it's toxic flesh and temperamental attitude have made many avoid attempting to gather its potent medicinal glands.</description>
		<statBases>
			<MoveSpeed>2.5</MoveSpeed>
			<ComfyTemperatureMin>-10</ComfyTemperatureMin>
			<ComfyTemperatureMax>50</ComfyTemperatureMax>
			<MarketValue>45</MarketValue>
			<Wildness>0</Wildness>
			<LeatherAmount>0</LeatherAmount>
			<ArmorRating_Blunt>0.15</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.35</ArmorRating_Sharp>
		</statBases>
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>ZWB_EggMediMolluscUnfertilized</eggUnfertilizedDef>
				<eggFertilizedDef>ZWB_EggMediMolluscFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>5.3</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>2~3</eggCountRange>
			</li>
		</comps>
		<race>
			<body>ZWB_SnailLike</body>
			<herdAnimal>true</herdAnimal>
			<baseBodySize>0.6</baseBodySize>
			<baseHungerRate>0.3</baseHungerRate>
			<baseHealthScale>0.60</baseHealthScale>
			<foodType>VegetarianRoughAnimal</foodType>
			<trainability>None</trainability>
			<meatLabel>snail meat</meatLabel>
			<lifeExpectancy>8</lifeExpectancy>
			<manhunterOnDamageChance>0.05</manhunterOnDamageChance>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.1</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.23</minAge>
					<!-- <soundWounded>Pawn_Boomrat_Wounded</soundWounded> -->
					<!-- <soundDeath>Pawn_Boomrat_Death</soundDeath> -->
					<!-- <soundCall>Pawn_Boomrat_Call</soundCall> -->
					<!-- <soundAngry>Pawn_Boomrat_Angry</soundAngry> -->
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
			<soundEating>Rodent_Eat</soundEating>
			<packAnimal>false</packAnimal>
		</race>
		<tradeTags>
			<li>AnimalUncommon</li>
		</tradeTags>
		<tools>
			<li>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>6</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.6</chanceFactor>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>ZWB_ToxicHeadbutt</li>
					<!-- <li>Blunt</li> -->
				</capacities>
				<power>5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.3</chanceFactor>
			</li>
		</tools>
	</ThingDef>


