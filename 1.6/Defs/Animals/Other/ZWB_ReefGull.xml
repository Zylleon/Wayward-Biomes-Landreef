	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggReefGullFertilized</defName>
		<label>reef gull egg (fert.)</label>
		<description>A fertilized reef gull egg. If all goes well, it should hatch into a baby reef gull. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(236,217,184)</color>
			<drawSize>1.0</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>12.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>5</hatcherDaystoHatch>
				<hatcherPawn>ZWB_ReefGull</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



	<ThingDef ParentName="EggUnfertBase">
		<defName>ZWB_EggReefGullUnfertilized</defName>
		<label>reef gull egg (unfert.)</label>
		<description>An unfertilized reef gull egg. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(228,185,135)</color>
			<drawSize>0.6</drawSize>
		</graphicData>
		<statBases>
			<MarketValue>7.0</MarketValue>
			<Nutrition>0.5</Nutrition>
		</statBases>
	</ThingDef>


</Defs>
