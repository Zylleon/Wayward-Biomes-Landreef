<?xml version="1.0" encoding="utf-8"?>
<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>ZWB_ReefGull</defName>
		<label>reef gull</label>
		<description>A mid-sized gull. Known for its distinctive sound, and for stealing food from humans.</description>
		<statBases>
			<MoveSpeed>5.4</MoveSpeed>
			<ComfyTemperatureMin>-10</ComfyTemperatureMin>
			<ComfyTemperatureMax>45</ComfyTemperatureMax>
			<MarketValue>100</MarketValue>
			<Wildness>0.25</Wildness>
			<MaxFlightTime>30</MaxFlightTime>
			<FlightCooldown>10</FlightCooldown>
		</statBases>
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>ZWB_EggReefGullUnfertilized</eggUnfertilizedDef>
				<eggFertilizedDef>ZWB_EggReefGullFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>2.1</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>1~2</eggCountRange>
			</li>
		</comps>
		<race>
			<body>Bird</body>
			<herdAnimal>true</herdAnimal>
			<baseBodySize>0.5</baseBodySize>
			<baseHungerRate>0.3</baseHungerRate>
			<baseHealthScale>0.5</baseHealthScale>
			<foodType>OmnivoreAnimal</foodType>
			<leatherDef>Leather_Bird</leatherDef>
			<trainability>Intermediate</trainability>
			<useMeatFrom>Cassowary</useMeatFrom>
			<lifeExpectancy>11</lifeExpectancy>
			<flightStartChanceOnJobStart>0.15</flightStartChanceOnJobStart>
			<canFlyIntoMap>true</canFlyIntoMap>
			<canLeaveMapFlying>true</canLeaveMapFlying>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.1</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.2</minAge>
					<soundWounded>ZWB_ReefGull_Wounded</soundWounded>
					<soundDeath>ZWB_ReefGull_Wounded</soundDeath>
					<soundCall>ZWB_ReefGull_Call</soundCall>
					<soundAngry>ZWB_ReefGull_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
			<soundEating>Bird_Eat</soundEating>
			<packAnimal>false</packAnimal>
		</race>
		<tradeTags>
			<li>AnimalCommon</li>
		</tradeTags>
		<tools>
			<li>
				<label>claws</label>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<power>11</power>
				<cooldownTime>1.5</cooldownTime>
				<linkedBodyPartsGroup>Feet</linkedBodyPartsGroup>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>14</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>beak</label>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>11</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>Beak</linkedBodyPartsGroup>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>14</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>6</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
		</tools>
	</ThingDef>


