<?xml version="1.0" encoding="utf-8"?>
<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>ZWB_BananaGraf</defName>
		<label>banana graf</label>
		<description>A peaceful herbivore that often travels in small herds, the banana graf is known for its bright coloring.</description>
		<statBases>
			<MoveSpeed>4.1</MoveSpeed>
			<ComfyTemperatureMin>-20</ComfyTemperatureMin>
			<ComfyTemperatureMax>50</ComfyTemperatureMax>
			<MarketValue>90</MarketValue>
			<Wildness>0.75</Wildness>
			<ToxicEnvironmentResistance>0.8</ToxicEnvironmentResistance>
		</statBases>
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>ZWB_EggBananaGrafUnfertilized</eggUnfertilizedDef>
				<eggFertilizedDef>ZWB_EggBananaGrafFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>6</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>1~2</eggCountRange>
			</li>
		</comps>
		<race>
			<body>ZWB_QuadrupedLandFish</body>
			<herdAnimal>false</herdAnimal>
			<baseBodySize>0.4</baseBodySize>
			<baseHungerRate>0.2</baseHungerRate>
			<baseHealthScale>0.45</baseHealthScale>
			<foodType>VegetarianRoughAnimal</foodType>
			<leatherDef>ZWB_Leather_Fishskin</leatherDef>
			<trainability>None</trainability>
			<useMeatFrom>ZWB_Jesterfish</useMeatFrom>
			<lifeExpectancy>7</lifeExpectancy>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.12</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.22</minAge>
					<soundWounded>ZWB_SmallFish_Wounded</soundWounded>
					<soundDeath>ZWB_SmallFish_Death</soundDeath>
					<soundCall>ZWB_SmallFish_Call</soundCall>
					<soundAngry>ZWB_SmallFish_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
			<soundEating>Herbivore_Eat</soundEating>
			<packAnimal>false</packAnimal>
			<!-- <headPosPerRotation> -->
			<!-- <li>(0.0, 0, 0.09)</li> -->
			<!-- <li>(0.28, 0, 0)</li> -->
			<!-- <li>(0.0, 0, -0.04)</li> -->
			<!-- <li>(-0.28, 0, 0)</li> -->
			<!-- </headPosPerRotation> -->
		</race>
		<tradeTags>
			<li>AnimalCommon</li>
			<!-- <li>AnimalFarm</li> -->
		</tradeTags>
		<tools>
			<li>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>7</power>
				<cooldownTime>2.2</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.6</chanceFactor>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>6</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
			<li>
				<label>left flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>7.5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontLeftFlipper</linkedBodyPartsGroup>
			</li>
			<li>
				<label>right flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>7.5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontRightFlipper</linkedBodyPartsGroup>
			</li>
		</tools>
	</ThingDef>


