	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggBananaGrafFertilized</defName>
		<label>banana graf egg (fert.)</label>
		<description>A fertilized banana graf egg. If all goes well, it should hatch into a baby banana graf. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(237,190,98)</color>
			<drawSize>0.7</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>18.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>4</hatcherDaystoHatch>
				<hatcherPawn>ZWB_BananaGraf</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



