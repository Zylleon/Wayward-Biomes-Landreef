<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>ZWB_Melu</defName>
		<label>melu</label>
		<description>A huge, solitary herbivore. It is peaceful if left alone, but if provoked, will club any intruders to death with its powerful flippers.</description>
		<statBases>
			<MoveSpeed>3.0</MoveSpeed>
			<ComfyTemperatureMin>-20</ComfyTemperatureMin>
			<MarketValue>500</MarketValue>
			<FilthRate>22</FilthRate>
			<Wildness>0.85</Wildness>
		</statBases>
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>ZWB_EggMeluUnfertilized</eggUnfertilizedDef>
				<eggFertilizedDef>ZWB_EggMeluFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>11</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>1~1</eggCountRange>
			</li>
		</comps>
		<race>
			<body>ZWB_QuadrupedLandFish</body>
			<herdAnimal>false</herdAnimal>
			<baseBodySize>3.5</baseBodySize>
			<baseHungerRate>0.9</baseHungerRate>
			<baseHealthScale>3.3</baseHealthScale>
			<foodType>VegetarianRoughAnimal</foodType>
			<leatherDef>Leather_Plain</leatherDef>
			<roamMtbDays>3</roamMtbDays>
			<trainability>None</trainability>
			<useMeatFrom>ZWB_Jesterfish</useMeatFrom>
			<lifeExpectancy>28</lifeExpectancy>
			<manhunterOnDamageChance>0.85</manhunterOnDamageChance>
			<manhunterOnTameFailChance>0.35</manhunterOnTameFailChance>
			
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.3</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.6</minAge>
					<soundWounded>Pawn_Muffalo_Wounded</soundWounded>
					<soundDeath>Pawn_Muffalo_Death</soundDeath>
					<soundCall>Pawn_Muffalo_Call</soundCall>
					<soundAngry>Pawn_Muffalo_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
			<soundEating>Herbivore_Eat</soundEating>
			<!-- <headPosPerRotation> -->
				<!-- <li>(0.0, 0, 0.09)</li> -->
				<!-- <li>(0.28, 0, 0)</li> -->
				<!-- <li>(0.0, 0, -0.04)</li> -->
				<!-- <li>(-0.28, 0, 0)</li> -->
			<!-- </headPosPerRotation> -->
		</race>
		<tradeTags>
			<li>AnimalUncommon</li>
			<!-- <li>AnimalFarm</li> -->
		</tradeTags>
		<tools>
			<li>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>14</power>
				<cooldownTime>2.6</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.7</chanceFactor>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>20</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
			<li>
				<label>left flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>16</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontLeftFlipper</linkedBodyPartsGroup>
			</li>
			<li>
				<label>right flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>16</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontRightFlipper</linkedBodyPartsGroup>
			</li>
		</tools>
	</ThingDef>


