	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggMeluFertilized</defName>
		<label>melu egg (fert.)</label>
		<description>A fertilized melu egg. If all goes well, it should hatch into a baby melu. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggOval</texPath>
			<color>(201,137,60)</color>
			<drawSize>1.2</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>56.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>15</hatcherDaystoHatch>
				<hatcherPawn>ZWB_Melu</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



