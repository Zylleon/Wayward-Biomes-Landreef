	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggFlumbieFertilized</defName>
		<label>flumbie egg (fert.)</label>
		<description>A fertilized flumbie egg. If all goes well, it should hatch into a baby flumbie. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(130,116,101)</color>
			<drawSize>0.6</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>12.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>5</hatcherDaystoHatch>
				<hatcherPawn>ZWB_Flumbie</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



	<ThingDef ParentName="EggUnfertBase">
		<defName>ZWB_EggFlumbieUnfertilized</defName>
		<label>flumbie egg (unfert.)</label>
		<description>An unfertilized flumbie egg. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(153,144,136)</color>
			<drawSize>0.6</drawSize>
		</graphicData>
		<statBases>
			<MarketValue>7.0</MarketValue>
			<Nutrition>0.5</Nutrition>
		</statBases>
	</ThingDef>


</Defs>
