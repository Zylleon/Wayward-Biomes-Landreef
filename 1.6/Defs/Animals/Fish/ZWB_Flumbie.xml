<?xml version="1.0" encoding="utf-8"?>
<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>ZWB_Flumbie</defName>
		<label>flumbie</label>
		<description>A small schooling creature that makes its home in tidewrack reefs. Many consider it a nuisance, as it is known for stealing food from humans.</description>
		<statBases>
			<MoveSpeed>4.2</MoveSpeed>
			<ComfyTemperatureMin>-10</ComfyTemperatureMin>
			<MarketValue>40</MarketValue>
			<Wildness>0.5</Wildness>
			<ToxicEnvironmentResistance>0.9</ToxicEnvironmentResistance>
		</statBases>
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>ZWB_EggFlumbieUnfertilized</eggUnfertilizedDef>
				<eggFertilizedDef>ZWB_EggFlumbieFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>2.7</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>1~2</eggCountRange>
			</li>
		</comps>
		<race>
			<body>ZWB_BipedLandFish</body>
			<herdAnimal>true</herdAnimal>
			<baseBodySize>0.16</baseBodySize>
			<baseHungerRate>0.1</baseHungerRate>
			<baseHealthScale>0.30</baseHealthScale>
			<foodType>OmnivoreAnimal</foodType>
			<leatherDef>ZWB_Leather_Fishskin</leatherDef>
			<trainability>None</trainability>
			<useMeatFrom>ZWB_Jesterfish</useMeatFrom>
			<lifeExpectancy>6</lifeExpectancy>
			<roamMtbDays>3.5</roamMtbDays>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.08</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.16</minAge>
					<soundWounded>ZWB_Flumbie_Wounded</soundWounded>
					<soundDeath>ZWB_Flumbie_Death</soundDeath>
					<soundCall>ZWB_Flumbie_Call</soundCall>
					<soundAngry>ZWB_Flumbie_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
			<soundEating>Rodent_Eat</soundEating>
			<packAnimal>false</packAnimal>
			<!-- <headPosPerRotation> -->
			<!-- <li>(0.0, 0, 0.09)</li> -->
			<!-- <li>(0.28, 0, 0)</li> -->
			<!-- <li>(0.0, 0, -0.04)</li> -->
			<!-- <li>(-0.28, 0, 0)</li> -->
			<!-- </headPosPerRotation> -->
		</race>
		<tradeTags>
			<li>AnimalCommon</li>
		</tradeTags>
		<tools>
			<li>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>5</power>
				<cooldownTime>1.8</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.7</chanceFactor>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>3</power>
				<cooldownTime>2.2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
			<li>
				<label>left flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>3</power>
				<cooldownTime>1.6</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontLeftFlipper</linkedBodyPartsGroup>
			</li>
			<li>
				<label>right flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>3</power>
				<cooldownTime>1.6</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontRightFlipper</linkedBodyPartsGroup>
			</li>
		</tools>
	</ThingDef>


