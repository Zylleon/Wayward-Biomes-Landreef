<?xml version="1.0" encoding="utf-8"?>
<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>ZWB_Flumbus</defName>
		<label>flumbus</label>
		<description>A largepack animal descended from a grouper. Flumbuses are peaceful if left alone.</description>
		<statBases>
			<MoveSpeed>4.1</MoveSpeed>
			<ComfyTemperatureMin>-15</ComfyTemperatureMin>
			<ComfyTemperatureMax>55</ComfyTemperatureMax>
			<MarketValue>350</MarketValue>
			<FilthRate>16</FilthRate>
			<Wildness>0.15</Wildness>
		</statBases>
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>ZWB_EggFlumbusUnfertilized</eggUnfertilizedDef>
				<eggFertilizedDef>ZWB_EggFlumbusFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>7.8</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>1~2</eggCountRange>
			</li>
		</comps>
		<race>
			<body>ZWB_BipedLandFish</body>
			<herdAnimal>true</herdAnimal>
			<baseBodySize>2.75</baseBodySize>
			<baseHungerRate>0.58</baseHungerRate>
			<baseHealthScale>1.9</baseHealthScale>
			<foodType>VegetarianRoughAnimal</foodType>
			<leatherDef>ZWB_Leather_HeavyFishHide</leatherDef>
			<useMeatFrom>ZWB_Jesterfish</useMeatFrom>
			<trainability>Intermediate</trainability>
			<lifeExpectancy>37</lifeExpectancy>
			<manhunterOnDamageChance>0.2</manhunterOnDamageChance>
			<manhunterOnTameFailChance>0.2</manhunterOnTameFailChance>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.24</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.3333</minAge>
					<soundWounded>ZWB_Melu_Wounded</soundWounded>
					<soundDeath>ZWB_Melu_Death</soundDeath>
					<soundCall>ZWB_Melu_Call</soundCall>
					<soundAngry>ZWB_Melu_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
			<soundEating>Herbivore_Eat</soundEating>
			<packAnimal>true</packAnimal>
			<!-- <headPosPerRotation> -->
				<!-- <li>(0.0, 0, 0.09)</li> -->
				<!-- <li>(0.28, 0, 0)</li> -->
				<!-- <li>(0.0, 0, -0.04)</li> -->
				<!-- <li>(-0.28, 0, 0)</li> -->
			<!-- </headPosPerRotation> -->
		</race>
		<tradeTags>
			<li>AnimalCommon</li>
			<!-- <li>AnimalFarm</li> -->
		</tradeTags>
		<tools>
			<li>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>10</power>
				<cooldownTime>2.6</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.7</chanceFactor>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>8</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
			<li>
				<label>left flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>12</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontLeftFlipper</linkedBodyPartsGroup>
			</li>
			<li>
				<label>right flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>12</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontRightFlipper</linkedBodyPartsGroup>
			</li>
		</tools>
	</ThingDef>


