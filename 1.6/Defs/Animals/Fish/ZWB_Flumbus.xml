	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggFlumbusFertilized</defName>
		<label>flumbus egg (fert.)</label>
		<description>A fertilized flumbus egg. If all goes well, it should hatch into a baby flumbus. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(195,195,195)</color>
			<drawSize>1.0</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>22.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>10</hatcherDaystoHatch>
				<hatcherPawn>ZWB_Flumbus</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



	<ThingDef ParentName="EggUnfertBase">
		<defName>ZWB_EggFlumbusUnfertilized</defName>
		<label>flumbus egg (unfert.)</label>
		<description>An unfertilized flumbus egg. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggOval</texPath>
			<color>(166,166,166)</color>
			<drawSize>1.0</drawSize>
		</graphicData>
		<statBases>
			<MarketValue>15.0</MarketValue>
			<Nutrition>0.5</Nutrition>
		</statBases>
	</ThingDef>


</Defs>

