	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggIronheadDunkFertilized</defName>
		<label>ironhead dunk (fert.)</label>
		<description>A fertilized ironhead dunk egg. If all goes well, it should hatch into a baby ironhead dunk. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggOval</texPath>
			<color>(130,110,87)</color>
			<drawSize>1.1</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>63.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>8.5</hatcherDaystoHatch>
				<hatcherPawn>ZWB_IronheadDunk</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



