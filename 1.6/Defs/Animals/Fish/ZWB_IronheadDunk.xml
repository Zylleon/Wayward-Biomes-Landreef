<?xml version="1.0" encoding="utf-8"?>
<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>ZWB_IronheadDunk</defName>
		<label>ironhead dunk</label>
		<description>A large apex predator of the reef, the Ironhead Dunk is known for its incredible bite force and thick skull.</description>
		<statBases>
			<MoveSpeed>4.8</MoveSpeed>
			<ComfyTemperatureMin>-10</ComfyTemperatureMin>
			<ComfyTemperatureMax>60</ComfyTemperatureMax>
			<MarketValue>3600</MarketValue>
			<Wildness>0.99</Wildness>
			<ArmorRating_Sharp>0.50</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.35</ArmorRating_Blunt>
			<ArmorRating_Heat>0.35</ArmorRating_Heat>
		</statBases>
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>ZWB_EggIronheadDunkUnfertilized</eggUnfertilizedDef>
				<eggFertilizedDef>ZWB_EggIronheadDunkFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>9</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>1~1</eggCountRange>
			</li>
		</comps>
		<race>
			<body>ZWB_QuadrupedLandFish</body>
			<herdAnimal>false</herdAnimal>
			<baseBodySize>2.5</baseBodySize>
			<baseHungerRate>0.45</baseHungerRate>
			<baseHealthScale>3.0</baseHealthScale>
			<!-- <maxPreyBodySize>2.3</maxPreyBodySize> -->
			<foodType>CarnivoreAnimalStrict</foodType>
			<leatherDef>ZWB_Leather_Ironhide</leatherDef>
			<useMeatFrom>ZWB_Jesterfish</useMeatFrom>
			<trainability>Intermediate</trainability>
			<lifeExpectancy>36</lifeExpectancy>
			<manhunterOnTameFailChance>0.85</manhunterOnTameFailChance>
			<manhunterOnDamageChance>1.00</manhunterOnDamageChance>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.35</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.6</minAge>
					<soundWounded>ZWB_Dunk_Wounded</soundWounded>
					<soundDeath>ZWB_Dunk_Death</soundDeath>
					<soundCall>ZWB_Dunk_Call</soundCall>
					<soundAngry>ZWB_Dunk_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
			<soundEating>PredatorSmall_Eat</soundEating>
			<packAnimal>false</packAnimal>
			<predator>true</predator>
		</race>
		<tradeTags>
			<li>AnimalExotic</li>
			<li>AnimalFighter</li>
		</tradeTags>
		<tools>
			<li>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>28</power>
				<cooldownTime>1.7</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.7</chanceFactor>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>18</power>
				<cooldownTime>1.8</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>22</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>left flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>14</power>
				<cooldownTime>1.8</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontLeftFlipper</linkedBodyPartsGroup>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>20</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>right flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>14</power>
				<cooldownTime>1.8</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontRightFlipper</linkedBodyPartsGroup>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>20</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
		</tools>
	</ThingDef>


