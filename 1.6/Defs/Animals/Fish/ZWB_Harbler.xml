	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggHarblerFertilized</defName>
		<label>harbler egg (fert.)</label>
		<description>A fertilized harbler egg. If all goes well, it should hatch into a baby harbler. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(186,61,84)</color>
			<drawSize>0.7</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>28.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>6</hatcherDaystoHatch>
				<hatcherPawn>ZWB_Harbler</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



	<ThingDef ParentName="EggUnfertBase">
		<defName>ZWB_EggHarblerUnfertilized</defName>
		<label>harbler egg (unfert.)</label>
		<description>An unfertilized harbler egg. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggRound</texPath>
			<color>(135,68,80)</color>
			<drawSize>0.7</drawSize>
		</graphicData>
		<statBases>
			<MarketValue>17.0</MarketValue>
			<Nutrition>0.5</Nutrition>
		</statBases>
	</ThingDef>


</Defs>

