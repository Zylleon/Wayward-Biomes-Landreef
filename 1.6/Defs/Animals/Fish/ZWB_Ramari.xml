<?xml version="1.0" encoding="utf-8"?>
<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>ZWB_Ramari</defName>
		<label>ramari</label>
		<description>A small schooling fish which makes its home in tidewrack reefs. Ramari are quite quick, helping them to escape from predators or hunters.</description>
		<statBases>
			<MoveSpeed>5.8</MoveSpeed>
			<ComfyTemperatureMin>-20</ComfyTemperatureMin>
			<MarketValue>120</MarketValue>
			<Wildness>0.6</Wildness>
		</statBases>
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>ZWB_EggRamariUnfertilized</eggUnfertilizedDef>
				<eggFertilizedDef>ZWB_EggRamariFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>7</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>1~2</eggCountRange>
			</li>
		</comps>
		<race>
			<body>ZWB_QuadrupedLandFish</body>
			<herdAnimal>true</herdAnimal>
			<baseBodySize>0.75</baseBodySize>
			<baseHungerRate>0.30</baseHungerRate>
			<baseHealthScale>0.85</baseHealthScale>
			<foodType>VegetarianRoughAnimal</foodType>
			<leatherDef>ZWB_Leather_FishHide</leatherDef>
			<trainability>None</trainability>
			<roamMtbDays>2</roamMtbDays>
			<useMeatFrom>ZWB_Jesterfish</useMeatFrom>
			<lifeExpectancy>7</lifeExpectancy>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.10</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.25</minAge>
					<soundWounded>Pawn_Muffalo_Wounded</soundWounded>
					<soundDeath>Pawn_Muffalo_Death</soundDeath>
					<soundCall>Pawn_Muffalo_Call</soundCall>
					<soundAngry>Pawn_Muffalo_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
			<soundEating>Herbivore_Eat</soundEating>
			<packAnimal>false</packAnimal>
			<!-- <headPosPerRotation> -->
			<!-- <li>(0.0, 0, 0.09)</li> -->
			<!-- <li>(0.28, 0, 0)</li> -->
			<!-- <li>(0.0, 0, -0.04)</li> -->
			<!-- <li>(-0.28, 0, 0)</li> -->
			<!-- </headPosPerRotation> -->
		</race>
		<tradeTags>
			<li>AnimalCommon</li>
			<!-- <li>AnimalFarm</li> -->
		</tradeTags>
		<tools>
			<li>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>7.2</power>
				<cooldownTime>2.6</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.7</chanceFactor>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>7.5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
			<li>
				<label>left flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>6.5</power>
				<cooldownTime>1.9</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontLeftFlipper</linkedBodyPartsGroup>
			</li>
			<li>
				<label>right flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>6.5</power>
				<cooldownTime>1.9</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontRightFlipper</linkedBodyPartsGroup>
			</li>
		</tools>
	</ThingDef>


