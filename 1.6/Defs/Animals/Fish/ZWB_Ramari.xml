		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggOval</texPath>
			<color>(174,194,136)</color>
			<drawSize>0.7</drawSize>
		</graphicData>
		<statBases>
			<MarketValue>11.0</MarketValue>
			<Nutrition>0.5</Nutrition>
		</statBases>
	</ThingDef>


