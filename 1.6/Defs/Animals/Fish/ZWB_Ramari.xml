	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggRamariFertilized</defName>
		<label>ramari egg (fert.)</label>
		<description>A fertilized ramari egg. If all goes well, it should hatch into a baby ramari. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggOval</texPath>
			<color>(193,222,133)</color>
			<drawSize>0.7</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>18.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>6</hatcherDaystoHatch>
				<hatcherPawn>ZWB_Ramari</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



