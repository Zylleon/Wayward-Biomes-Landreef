<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!-- Dredgewood -->

	<ThingDef ParentName="ResourceVerbBase">
		<defName>ZWB_Dredgewood</defName>
		<label>dredgewood</label>
		<description>A woody material gathered from certain dry land corals. Useful for building structures and weapons, and generally considered to be quite pretty.</description>
		<graphicData>
			<texPath>ZWB_Textures/Things/Dredgewood</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<equippedAngleOffset>-20</equippedAngleOffset>
		<soundInteract>Wood_Drop</soundInteract>
		<soundDrop>Wood_Drop</soundDrop>
		<statBases>
			<MarketValue>1.8</MarketValue>
			<MaxHitPoints>130</MaxHitPoints>
			<Mass>0.4</Mass>
			<Flammability>0.6</Flammability>
			<DeteriorationRate>0.3</DeteriorationRate>
			<StuffPower_Armor_Sharp>0.60</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>0.50</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>0.50</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>8</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>6</StuffPower_Insulation_Heat>
			<SharpDamageMultiplier>0.55</SharpDamageMultiplier>
			<BluntDamageMultiplier>0.8</BluntDamageMultiplier>
		</statBases>
		<burnableByRecipe>true</burnableByRecipe>
		<healthAffectsPrice>false</healthAffectsPrice>
		<minRewardCount>10</minRewardCount>
		<stuffProps>
			<stuffAdjective>dredgewood</stuffAdjective>
			<categories>
				<li>Woody</li>
			</categories>
			<commonality>0.2</commonality>
			<color>(217,160,154)</color>
			<constructEffect>ConstructWood</constructEffect>
			<appearance>Planks</appearance>
			<soundImpactBullet>BulletImpact_Wood</soundImpactBullet>
			<soundMeleeHitSharp>MeleeHit_Wood</soundMeleeHitSharp>
			<soundMeleeHitBlunt>MeleeHit_Wood</soundMeleeHitBlunt>
			<soundImpactMelee>Pawn_Melee_Punch_HitBuilding_Wood</soundImpactMelee>
			<statFactors>
				<MaxHitPoints>0.65</MaxHitPoints>
				<Beauty>1.5</Beauty>
				<Flammability>0.6</Flammability>
				<WorkToMake>0.7</WorkToMake>
				<WorkToBuild>0.7</WorkToBuild>
				<DoorOpenSpeed>1.2</DoorOpenSpeed>
			</statFactors>
			<canSuggestUseDefaultStuff>true</canSuggestUseDefaultStuff>
		</stuffProps>
		<isTechHediff>true</isTechHediff>
		<thingCategories>
			<li>ResourcesRaw</li>
		</thingCategories>
		<techHediffsTags>
			<li>Poor</li>
		</techHediffsTags>
		<weaponClasses>
			<li>Melee</li>
			<li>MeleeBlunt</li>
			<li>Neolithic</li>
		</weaponClasses>
		<tools>
			<li>
				<label>dredgewood log</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>8</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
		<allowedArchonexusCount>150</allowedArchonexusCount>
	</ThingDef>

