<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!-- Dredgewood -->

	<ThingDef ParentName="ResourceVerbBase">
		<defName>ZWB_Dredgewood</defName>
		<label>dredgewood</label>
		<description>A woody material gathered from certain dry land corals. Useful for building structures and weapons, and generally considered to be quite pretty.</description>
		<graphicData>
			<texPath>ZWB_Textures/Things/Dredgewood</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<equippedAngleOffset>-20</equippedAngleOffset>
		<soundInteract>Wood_Drop</soundInteract>
		<soundDrop>Wood_Drop</soundDrop>
		<statBases>
			<MarketValue>1.8</MarketValue>
			<MaxHitPoints>130</MaxHitPoints>
			<Mass>0.4</Mass>
			<Flammability>0.6</Flammability>
			<DeteriorationRate>0.3</DeteriorationRate>
			<StuffPower_Armor_Sharp>0.60</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>0.50</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>0.50</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>8</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>6</StuffPower_Insulation_Heat>
			<SharpDamageMultiplier>0.55</SharpDamageMultiplier>
			<BluntDamageMultiplier>0.8</BluntDamageMultiplier>
		</statBases>
		<burnableByRecipe>true</burnableByRecipe>
		<healthAffectsPrice>false</healthAffectsPrice>
		<minRewardCount>10</minRewardCount>
		<stuffProps>
			<stuffAdjective>dredgewood</stuffAdjective>
			<categories>
				<li>Woody</li>
			</categories>
			<commonality>0.2</commonality>
			<color>(217,160,154)</color>
			<constructEffect>ConstructWood</constructEffect>
			<appearance>Planks</appearance>
			<soundImpactBullet>BulletImpact_Wood</soundImpactBullet>
			<soundMeleeHitSharp>MeleeHit_Wood</soundMeleeHitSharp>
			<soundMeleeHitBlunt>MeleeHit_Wood</soundMeleeHitBlunt>
			<soundImpactMelee>Pawn_Melee_Punch_HitBuilding_Wood</soundImpactMelee>
			<statFactors>
				<MaxHitPoints>0.65</MaxHitPoints>
				<Beauty>1.5</Beauty>
				<Flammability>0.6</Flammability>
				<WorkToMake>0.7</WorkToMake>
				<WorkToBuild>0.7</WorkToBuild>
				<DoorOpenSpeed>1.2</DoorOpenSpeed>
			</statFactors>
			<canSuggestUseDefaultStuff>true</canSuggestUseDefaultStuff>
		</stuffProps>
		<isTechHediff>true</isTechHediff>
		<thingCategories>
			<li>ResourcesRaw</li>
		</thingCategories>
		<techHediffsTags>
			<li>Poor</li>
		</techHediffsTags>
		<weaponClasses>
			<li>Melee</li>
			<li>MeleeBlunt</li>
			<li>Neolithic</li>
		</weaponClasses>
		<tools>
			<li>
				<label>dredgewood log</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>8</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
		<allowedArchonexusCount>150</allowedArchonexusCount>
	</ThingDef>

	<!-- coralith -->
	<ThingDef ParentName="StoneBlocksBase">
		<defName>ZWB_CoralithChunk</defName>
		<label>coralith</label>
		<description>A chunk of coralith. Can be used as stone.</description>
		<statBases>
			<BeautyOutdoors>0</BeautyOutdoors>
			<Mass>.85</Mass>
			<SharpDamageMultiplier>0.5</SharpDamageMultiplier>
		</statBases>
		<soundDrop>ChunkRock_Drop</soundDrop>
		<graphicData>
			<texPath>ZWB_Textures/Things/Coralith</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
			<flipExtraRotation>80</flipExtraRotation>
			<!-- <color>(128,86,98)</color> -->
		</graphicData>
		<stuffProps>
			<color>(128,86,98)</color>
			<soundImpactBullet>BulletImpact_Ground</soundImpactBullet>
			<soundMeleeHitSharp>MeleeHit_Stone</soundMeleeHitSharp>
			<soundMeleeHitBlunt>MeleeHit_Stone</soundMeleeHitBlunt>
			<soundImpactMelee>Pawn_Melee_Punch_HitBuilding_Stone</soundImpactMelee>
			<stuffAdjective>coralith</stuffAdjective>
			<statFactors>
				<Beauty>1.4</Beauty>
				<MaxHitPoints>1.5</MaxHitPoints>
				<WorkToBuild>5.0</WorkToBuild>
				<WorkToMake>1.1</WorkToMake>
			</statFactors>
			<canSuggestUseDefaultStuff>true</canSuggestUseDefaultStuff>
		</stuffProps>
	</ThingDef>


	<!-- leathers -->

	<ThingDef ParentName="LeatherBase">
		<defName>ZWB_Leather_Fishskin</defName>
		<label>fishskin</label>
		<description>Lightweight, thin fish skin. Probably harvested from a small animal. Less protective than other leathers.</description>
		<graphicData>
			<color>(230,206,118)</color>
		</graphicData>
		<statBases>
			<MarketValue>1.7</MarketValue>
			<Flammability>0.8</Flammability>
			<StuffPower_Armor_Sharp>0.49</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>0.18</StuffPower_Armor_Blunt>
			<StuffPower_Insulation_Cold>8</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>16</StuffPower_Insulation_Heat>
		</statBases>
		<stuffProps>
			<color>(230,206,118)</color>
			<commonality>0.15</commonality>
			<statFactors>
				<MaxHitPoints>1.0</MaxHitPoints>
			</statFactors>
		</stuffProps>
	</ThingDef>


	<ThingDef ParentName="LeatherBase">
		<defName>ZWB_Leather_FishHide</defName>
		<label>fish hide</label>
		<description>Tanned, dried, scraped fish skin. A good traditional material for making clothes and bags.</description>
		<graphicData>
			<color>(199,92,73)</color>
		</graphicData>
		<statBases>
			<MarketValue>2.4</MarketValue>
			<Flammability>0.8</Flammability>
			<StuffPower_Armor_Sharp>0.72</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>0.29</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>1.6</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>16</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>20</StuffPower_Insulation_Heat>
		</statBases>
		<stuffProps>
			<color>(199,92,73)</color>
			<commonality>0.1</commonality>
			<statFactors>
				<Flammability>0.8</Flammability>
			</statFactors>
		</stuffProps>
	</ThingDef>
	
	
<!-- Other textiles -->


