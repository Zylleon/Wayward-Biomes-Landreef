<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingDef ParentName="PlantBase">
		<defName>ZWB_AmethystVeil</defName>
		<label>amethyst veil</label>
		<description>A foliose coral, which can be harvested and refined into a textile. This soft, luxurious fabric is highly prized.</description>
		<neverMultiSelect>false</neverMultiSelect>
		<statBases>
			<MaxHitPoints>60</MaxHitPoints>
			<Nutrition>0.2</Nutrition>
		</statBases>
		<graphicData>
			<texPath>ZWB_Textures/Plants/AmethystVeil</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shadowData>
				<volume>(0.15, 0.18, 0.15)</volume>
				<offset>(0,0,-0.38)</offset>
			</shadowData>
		</graphicData>
		<selectable>true</selectable>
		<pathCost>14</pathCost>
		<ingestible/>
		<plant>
			<fertilityMin>0.5</fertilityMin>
			<fertilitySensitivity>1.0</fertilitySensitivity>
			<immatureGraphicPath>ZWB_Textures/Plants/AmethystVeil_Immature</immatureGraphicPath>
			<dieIfLeafless>false</dieIfLeafless>
			<harvestWork>400</harvestWork>
			<harvestTag>Standard</harvestTag>
			<harvestedThingDef>ZWB_AmethystVeilCloth</harvestedThingDef>
			<harvestYield>9</harvestYield>
			<topWindExposure>0.2</topWindExposure>
			<visualSizeRange>0.6~1.2</visualSizeRange>
			<wildOrder>3</wildOrder>
			<wildClusterRadius>5</wildClusterRadius>
			<wildClusterWeight>250</wildClusterWeight>
			<mustBeWildToSow>true</mustBeWildToSow>
			<growDays>7</growDays>
			<sowWork>800</sowWork>
			<sowMinSkill>7</sowMinSkill>
			<sowTags>
				<li>Ground</li>
				<li>Hydroponic</li>
			</sowTags>
			<sowResearchPrerequisites>
				<li>Devilstrand</li>
			</sowResearchPrerequisites>
		</plant>
	</ThingDef>



	<ThingDef ParentName="ResourceBase">
		<defName>ZWB_AmethystVeilCloth</defName>
		<label>amethyst veil</label>
		<description>Fabric harvested from a foliose coral. The interlocking fibers make it especially protective against sharp weapons, and it is difficult to burn. This soft, luxurious fabric is highly prized.</description>
		<graphicData>
			<texPath>ZWB_Textures/Things/AmethystVeilCloth</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<MarketValue>4.9</MarketValue>
			<Mass>0.032</Mass>
			<Flammability>0.3</Flammability>
			<DeteriorationRate>3</DeteriorationRate>
			<StuffPower_Armor_Sharp>1.42</StuffPower_Armor_Sharp>
			<StuffPower_Armor_Blunt>0.40</StuffPower_Armor_Blunt>
			<StuffPower_Armor_Heat>2.25</StuffPower_Armor_Heat>
			<StuffPower_Insulation_Cold>15</StuffPower_Insulation_Cold>
			<StuffPower_Insulation_Heat>29</StuffPower_Insulation_Heat>
		</statBases>
		<burnableByRecipe>true</burnableByRecipe>
		<healthAffectsPrice>false</healthAffectsPrice>
		<minRewardCount>30</minRewardCount>
		<stuffProps>
			<categories>
				<li>Fabric</li>
			</categories>
			<commonality>0.20</commonality>
			<color>(101,77,135)</color>
			<statFactors>
				<Flammability>0.27</Flammability>
				<MaxHitPoints>0.85</MaxHitPoints>
				<Beauty>3.5</Beauty>
			</statFactors>
		</stuffProps>
		<thingCategories>
			<li>Textiles</li>
		</thingCategories>
		<allowedArchonexusCount>80</allowedArchonexusCount>
	</ThingDef>



</Defs>

