<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingDef ParentName="PlantBase">
		<defName>ZWB_MoonLily</defName>
		<label>moon lily</label>
		<description>A squat plant with a broad basal structure that produces gelatinous fruiting bodies. These nutrient-rich masses are edible, and can be eaten for more restful sleep.</description>
		<neverMultiSelect>false</neverMultiSelect>
		<statBases>
			<MaxHitPoints>120</MaxHitPoints>
			<Nutrition>0.50</Nutrition>
		</statBases>
		<graphicData>
			<texPath>ZWB_Textures/Plants/MoonLily</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shadowData>
				<volume>(0.35, 0.35, 0.25)</volume>
				<offset>(0,0,-0.25)</offset>
			</shadowData>
		</graphicData>
		<selectable>true</selectable>
		<pathCost>30</pathCost>
		<ingestible/>
		<plant>
			<fertilityMin>0.5</fertilityMin>
			<fertilitySensitivity>0.5</fertilitySensitivity>
			<growDays>9.5</growDays>
			<immatureGraphicPath>ZWB_Textures/Plants/MoonLily_Immature</immatureGraphicPath>
			<harvestYield>21</harvestYield>
			<harvestWork>250</harvestWork>
			<harvestTag>Standard</harvestTag>
			<harvestAfterGrowth>0.30</harvestAfterGrowth>
			<harvestedThingDef>ZWB_MoonJelly</harvestedThingDef>
			<wildClusterRadius>5</wildClusterRadius>
			<wildClusterWeight>250</wildClusterWeight>
			<visualSizeRange>0.6~1.0</visualSizeRange>
			<topWindExposure>0.3</topWindExposure>
			<wildOrder>2</wildOrder>
			<purpose>Food</purpose>
			<humanFoodPlant>true</humanFoodPlant>
			<mustBeWildToSow>true</mustBeWildToSow>
			<sowWork>800</sowWork>
			<sowMinSkill>0</sowMinSkill>
			<sowTags>
				<li>Ground</li>
				<li>Hydroponic</li>
			</sowTags>
		</plant>
	</ThingDef>




	<ThingDef ParentName="PlantFoodRawBase">
		<defName>ZWB_MoonJelly</defName>
		<label>moon jelly</label>
		<description>An edible gelatinous mass. Confers an excellent night's sleep.</description>
		<graphicData>
			<texPath>ZWB_Textures/Things/MoonJelly</texPath>
		</graphicData>
		<statBases>
			<MarketValue>2.2</MarketValue>
			<Mass>0.031</Mass>
		</statBases>
		<comps>
			<li Class="CompProperties_Rottable">
				<daysToRotStart>10</daysToRotStart>
				<rotDestroys>true</rotDestroys>
			</li>
		</comps>
		<ingestible>
			<preferability>RawTasty</preferability>
			<tasteThought/>
			<foodType>VegetableOrFruit</foodType>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>ZWB_MoonJellyHigh</hediffDef>
					<severity>1</severity>
				</li>
			</outcomeDoers>
		</ingestible>
	</ThingDef>



	<HediffDef>
		<defName>ZWB_MoonJellyHigh</defName>
		<label>moon jelly tranquillity</label>
		<description>I feel calm and peaceful, ready to rest.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>12500~16500</disappearsAfterTicks>
			</li>
		</comps>
		<stages>
			<li>
				<socialFightChanceFactor>0.9</socialFightChanceFactor>
				<statFactors>
					<RestRateMultiplier>1.2</RestRateMultiplier>
				</statFactors>
			</li>
		</stages>
	</HediffDef>


</Defs>

