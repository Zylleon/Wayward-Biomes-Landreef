<?xml version="1.0" encoding="utf-8"?>
<Defs>




	<ThingDef ParentName="BushBase">
		<defName>ZWB_AmberFrill</defName>
		<label>amber frill</label>
		<description>A kind of sea fan adapted for life on land. It grows quickly at the expense of quality, resulting in a large but extraordinarily delicate plant.</description>
		<statBases>
			<Beauty>3</Beauty>
			<BeautyOutdoors>3</BeautyOutdoors>
			<MaxHitPoints>20</MaxHitPoints>
			<Nutrition>0.10</Nutrition>
			<Flammability>1.5</Flammability>
		</statBases>
		<altitudeLayer>Building</altitudeLayer>
		<graphicData>
			<texPath>ZWB_Textures/Plants/AmberFrill</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shaderType>TransparentPlant</shaderType>
			<shadowData>
				<volume>(0,0,0)</volume>
				<offset>(0,0,0)</offset>
			</shadowData>
		</graphicData>
		<fillPercent>0.10</fillPercent>
		<pathCost>20</pathCost>
		<plant>
			<wildClusterRadius>8</wildClusterRadius>
			<wildClusterWeight>150</wildClusterWeight>
			<growDays>3.5</growDays>
			<wildOrder>2</wildOrder>
			<visualSizeRange>0.4~2.1</visualSizeRange>
			<dieIfLeafless>true</dieIfLeafless>
			<harvestWork>30</harvestWork>
		</plant>
	</ThingDef>





	<ThingDef ParentName="BushBase">
		<defName>ZWB_LilacFrill</defName>
		<label>lilac frill</label>
		<description>A kind of sea fan adapted for life on land. It’s nice to look at, and commonly found in tidewrack reefs. Its flexible structure allows it to survive wind and shifting sand.</description>
		<statBases>
			<Beauty>8</Beauty>
			<BeautyOutdoors>8</BeautyOutdoors>
			<MaxHitPoints>80</MaxHitPoints>
			<Nutrition>0.25</Nutrition>
			<Flammability>0.8</Flammability>
		</statBases>
		<graphicData>
			<texPath>ZWB_Textures/Plants/LilacFrill</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shaderType>TransparentPlant</shaderType>
			<shadowData>
				<volume>(0,0,0)</volume>
				<offset>(0,0,0)</offset>
			</shadowData>
		</graphicData>
		<fillPercent>0.10</fillPercent>
		<pathCost>20</pathCost>
		<plant>
			<wildClusterRadius>3</wildClusterRadius>
			<wildClusterWeight>300</wildClusterWeight>
			<sowWork>750</sowWork>
			<sowTags>
				<li>Ground</li>
				<!-- <li>Decorative</li> --> <!-- can't plant this in plant pots, it's invisible -->
			</sowTags>
			<growDays>4.5</growDays>
			<growMinGlow>0.3</growMinGlow>
			<wildOrder>2</wildOrder>
			<purpose>Beauty</purpose>
		</plant>
	</ThingDef>






	<ThingDef ParentName="PlantBase">
		<defName>ZWB_CobaltScrunge</defName>
		<label>cobalt scrunge</label>
		<description>A blue sponge-like organism that filters minerals from the soil, found throughout tidewrack reefs.</description>
		<statBases>
			<MaxHitPoints>90</MaxHitPoints>
			<Nutrition>0.35</Nutrition>
		</statBases>
		<selectable>true</selectable>
		<pathCost>25</pathCost>
		<graphicData>
			<texPath>ZWB_Textures/Plants/CobaltScrunge</texPath>
			<graphicClass>Graphic_Random</graphicClass>
		</graphicData>
		<uiIconScale>0.85</uiIconScale>
		<plant>
			<fertilitySensitivity>0.5</fertilitySensitivity>
			<growDays>4.5</growDays>
			<wildClusterRadius>4</wildClusterRadius>
			<wildClusterWeight>70</wildClusterWeight>
			<visualSizeRange>0.4~0.9</visualSizeRange>
			<topWindExposure>0.20</topWindExposure>
			<wildOrder>2</wildOrder>
		</plant>
	</ThingDef>



	<ThingDef ParentName="BushBase">
		<defName>ZWB_AmberTube</defName>
		<label>amber tube</label>
		<description>A small orange tube coral that grows in clusters. It's nice to look at.</description>
		<statBases>
			<MaxHitPoints>75</MaxHitPoints>
			<Beauty>9</Beauty>
			<BeautyOutdoors>9</BeautyOutdoors>
			<Nutrition>0.4</Nutrition>
		</statBases>
		<pathCost>20</pathCost>
		<graphicData>
			<texPath>ZWB_Textures/Plants/AmberTube</texPath>
			<graphicClass>Graphic_Random</graphicClass>
		</graphicData>
		<ingestible/>
		<selectable>true</selectable>
		<plant>
			<fertilitySensitivity>0.0</fertilitySensitivity>
			<growDays>3.0</growDays>
			<fertilityMin>0.05</fertilityMin>
			<maxMeshCount>9</maxMeshCount>
			<visualSizeRange>0.35~0.8</visualSizeRange>
			<topWindExposure>0.2</topWindExposure>
			<wildClusterRadius>4</wildClusterRadius>
			<wildClusterWeight>150</wildClusterWeight>
			<wildOrder>1</wildOrder>
		</plant>
	</ThingDef>
	
	
	

