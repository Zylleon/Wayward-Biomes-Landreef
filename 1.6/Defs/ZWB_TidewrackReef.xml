<?xml version="1.0" encoding="utf-8"?>
<Defs>


	<BiomeDef>
		<defName>ZWB_TidewrackReef</defName>
		<label>Tidewrack reef</label>
		<description>The remnants of what was once a tropical coral reef. Over time, the oceans receded and the land dried up. Rather than follow the ocean, the flora and fauna that made the reef their home have instead adapted to land.</description>
		<texture>ZWB_Textures/TidewrackReef</texture>
		<workerClass>Tidewrack.BiomeWorker_TidewrackReef</workerClass>
		<settlementSelectionWeight>0.5</settlementSelectionWeight>
		<movementDifficulty>1.5</movementDifficulty>
		<animalDensity>5.0</animalDensity>
		<plantDensity>0.9</plantDensity>
		<wildPlantRegrowDays>12</wildPlantRegrowDays>
		<forageability>1</forageability>
		<foragedFood>ZWB_Algfruit</foragedFood>
		<maxFishPopulation>720</maxFishPopulation>
		<!-- <wildPlantsCareAboutLocalFertility>false</wildPlantsCareAboutLocalFertility> -->
		<fishTypes MayRequire="Ludeon.RimWorld.Odyssey">
			<freshwater_Common>
				<Fish_Tilapia MayRequire="Ludeon.RimWorld.Odyssey">1</Fish_Tilapia>
			</freshwater_Common>
			<freshwater_Uncommon>
				<Fish_Piranha MayRequire="Ludeon.RimWorld.Odyssey">1</Fish_Piranha>
			</freshwater_Uncommon>
			<saltwater_Common>
				<Fish_Bluefish MayRequire="Ludeon.RimWorld.Odyssey">1</Fish_Bluefish>
			</saltwater_Common>
			<saltwater_Uncommon>
				<Fish_Tuna MayRequire="Ludeon.RimWorld.Odyssey">1</Fish_Tuna>
				<Fish_Flounder MayRequire="Ludeon.RimWorld.Odyssey">1</Fish_Flounder>
			</saltwater_Uncommon>
			<rareCatchesSetMaker MayRequire="Ludeon.RimWorld.Odyssey">RareFishingCatches_Tropical</rareCatchesSetMaker>
		</fishTypes>
		<soundsAmbient>
			<li>Ambient_NightInsects_Standard</li>
		</soundsAmbient>
		<diseaseMtbDays>60</diseaseMtbDays>
		<diseases>
			<li>
				<diseaseInc>Disease_Flu</diseaseInc>
				<commonality>100</commonality>
			</li>
			<li>
				<diseaseInc>Disease_Plague</diseaseInc>
				<commonality>100</commonality>
			</li>
			<li>
				<diseaseInc>Disease_GutWorms</diseaseInc>
				<commonality>50</commonality>
			</li>
			<li>
				<diseaseInc>Disease_FibrousMechanites</diseaseInc>
				<commonality>30</commonality>
			</li>
			<li>
				<diseaseInc>Disease_SensoryMechanites</diseaseInc>
				<commonality>30</commonality>
			</li>
			<li>
				<diseaseInc>Disease_MuscleParasites</diseaseInc>
				<commonality>50</commonality>
			</li>

			<li>
				<diseaseInc>Disease_AnimalFlu</diseaseInc>
				<commonality>100</commonality>
			</li>
			<li>
				<diseaseInc>Disease_AnimalPlague</diseaseInc>
				<commonality>100</commonality>
			</li>
		</diseases>
		<riverbankTerrain>ZWB_BiogenicSand</riverbankTerrain>
		<waterShallowTerrain>WaterOceanShallow</waterShallowTerrain>
		<waterDeepTerrain>WaterOceanDeep</waterDeepTerrain>
		<terrainsByFertility>
			<li>
				<terrain>Sand</terrain>
				<min>-999</min>
				<max>0.25</max>
			</li>
			<li>
				<terrain>ZWB_GenicSand</terrain>
				<min>0.25</min>
				<max>0.65</max>
			</li>
			<li>
				<terrain>ZWB_BiogenicSand</terrain>
				<min>0.65</min>
				<max>999</max>
			</li>
		</terrainsByFertility>
		<terrainPatchMakers>
			<li>
				<perlinFrequency>0.022</perlinFrequency>
				<isPond>true</isPond>
				<thresholds>
					<li>
						<terrain>ZWB_BiogenicSand</terrain>
						<min>0.45</min>
						<max>0.82</max>
					</li>
					<li>
						<terrain>WaterOceanShallow</terrain>
						<min>0.82</min>
						<max>999</max>
					</li>
				</thresholds>
			</li>
		</terrainPatchMakers>

